use dioxus::prelude::*;
use std::collections::BTreeSet;

mod generated;

/// Launches the generated showcase application.
fn main() {
    launch(App);
}

impl dioxus_showcase::core::StoryTreeEntry for generated::ShowcaseComponentDefinition {
    /// Returns the route id for the generated component definition.
    fn story_id(&self) -> &str {
        &self.id
    }

    /// Returns the title used to place the story in the sidebar tree.
    fn story_title(&self) -> &str {
        &self.title
    }
}

#[derive(Routable, Clone, PartialEq, Debug)]
enum Route {
    #[route("{{route_root}}")]
    Home {},
    #[route("{{route_component}}")]
    Component { id: String },
    #[route("{{route_not_found}}")]
    NotFound { route: Vec<String> },
}

const COMPONENT_ROUTE_PREFIX: &str = "{{route_component_prefix}}";

#[derive(Clone, Copy, PartialEq, Eq)]
enum ThemeMode {
    Light,
    Dark,
}

impl ThemeMode {
    /// Returns the serialized theme token used in the shell DOM.
    fn as_str(self) -> &'static str {
        match self {
            Self::Light => "light",
            Self::Dark => "dark",
        }
    }

    /// Switches between light and dark theme modes.
    fn toggle(self) -> Self {
        match self {
            Self::Light => Self::Dark,
            Self::Dark => Self::Light,
        }
    }

    /// Returns the label shown by the theme toggle control.
    fn label(self) -> &'static str {
        match self {
            Self::Light => "Light",
            Self::Dark => "Dark",
        }
    }
}

/// Root application component for the generated showcase shell.
#[component]
fn App() -> Element {
    use_context_provider(|| Signal::new(None::<String>));
    let theme = use_context_provider(|| Signal::new(ThemeMode::Light));
    use_context_provider(generated::story_providers);

    rsx! {
        {{#each stylesheets}}
        document::Stylesheet { href: asset!("{{this}}") }
        {{/each}}
        div { class: "app-shell", "data-theme": theme.read().as_str(),
            Router::<Route> {}
        }
    }
}

/// Builds the filtered sidebar navigation tree for the currently selected tag.
fn showcase_navigation(
    selected_tag: Option<&str>,
) -> Vec<dioxus_showcase::core::StoryNavigationNode> {
    let components = generated::showcase_components();
    let filtered = components
        .iter()
        .filter(|component| {
            selected_tag
                .map(|tag| component.tags.iter().any(|component_tag| component_tag == tag))
                .unwrap_or(true)
        })
        .collect::<Vec<_>>();
    dioxus_showcase::core::build_story_navigation(&filtered)
}

/// Collects all distinct story tags exposed by the generated stories.
fn showcase_tags() -> Vec<String> {
    let mut tags = BTreeSet::new();
    for component in generated::showcase_components() {
        for tag in component.tags {
            tags.insert(tag);
        }
    }
    tags.into_iter().collect()
}

/// Returns `true` when a navigation node contains the active story somewhere below it.
fn node_contains_active_story(
    node: &dioxus_showcase::core::StoryNavigationNode,
    active_id: Option<&str>,
) -> bool {
    node.story_id.as_deref() == active_id
        || node.children.iter().any(|child| node_contains_active_story(child, active_id))
}

/// Renders the showcase sidebar with theme controls, tag filters, and story navigation.
#[component]
fn Sidebar(active_id: Option<String>) -> Element {
    let mut selected_tag = use_context::<Signal<Option<String>>>();
    let mut theme = use_context::<Signal<ThemeMode>>();
    let active_tag = selected_tag.read().clone();
    let active_theme = *theme.read();
    let all_tags = showcase_tags();
    let navigation = showcase_navigation(active_tag.as_deref());

    rsx! {
        aside { class: "sidebar",
            h1 { "Showcase" }
            div { class: "theme-panel",
                h2 { class: "theme-panel-title", "Theme" }
                button {
                    class: "theme-toggle",
                    onclick: move |_| theme.set(active_theme.toggle()),
                    span { class: "theme-toggle-label", "{active_theme.label()}" }
                    span { class: "theme-toggle-track",
                        span { class: "theme-toggle-thumb" }
                    }
                }
            }
            div { class: "tag-filter-panel",
                div { class: "tag-filter-header",
                    h2 { class: "tag-filter-title", "Tags" }
                    if let Some(tag) = active_tag.as_ref() {
                        button {
                            class: "tag-filter-clear",
                            onclick: move |_| selected_tag.set(None),
                            "Clear {tag}"
                        }
                    }
                }
                if all_tags.is_empty() {
                    p { class: "muted", "No tags available" }
                } else {
                    div { class: "tag-filter-list",
                        button {
                            class: if active_tag.is_none() { "tag-filter-chip active" } else { "tag-filter-chip" },
                            onclick: move |_| selected_tag.set(None),
                            "All"
                        }
                        for tag in all_tags {
                            {
                                let is_active = active_tag.as_deref() == Some(tag.as_str());
                                rsx! {
                                    button {
                                        key: "{tag}",
                                        class: if is_active { "tag-filter-chip active" } else { "tag-filter-chip" },
                                        onclick: move |_| selected_tag.set(Some(tag.clone())),
                                        "{tag}"
                                    }
                                }
                            }
                        }
                    }
                }
            }
            StoryTree { nodes: navigation, active_id }
        }
    }
}

/// Renders one level of the story navigation tree.
#[component]
fn StoryTree(
    nodes: Vec<dioxus_showcase::core::StoryNavigationNode>,
    active_id: Option<String>,
) -> Element {
    rsx! {
        ul { class: "component-tree",
            for node in nodes {
                StoryTreeNode { node, active_id: active_id.clone() }
            }
        }
    }
}

/// Renders a single navigation node as either a leaf link or collapsible branch.
#[component]
fn StoryTreeNode(
    node: dioxus_showcase::core::StoryNavigationNode,
    active_id: Option<String>,
) -> Element {
    let is_active = node.story_id.as_deref() == active_id.as_deref();
    let is_open = node_contains_active_story(&node, active_id.as_deref());

    rsx! {
        li { class: "tree-node",
            if node.children.is_empty() {
                if let Some(story_id) = node.story_id.as_ref() {
                    Link {
                        to: Route::Component { id: story_id.clone() },
                        class: if is_active { "tree-leaf-link active" } else { "tree-leaf-link" },
                        "{node.segment}"
                    }
                }
            } else {
                details { class: "tree-branch", open: is_open,
                    summary { class: "tree-summary",
                        span { class: "tree-summary-label", "{node.segment}" }
                    }
                    div { class: "tree-branch-body",
                        if let Some(story_id) = node.story_id.as_ref() {
                            Link {
                                to: Route::Component { id: story_id.clone() },
                                class: if is_active { "tree-branch-link active" } else { "tree-branch-link" },
                                "Overview"
                            }
                        }
                        StoryTree { nodes: node.children.clone(), active_id: active_id.clone() }
                    }
                }
            }
        }
    }
}

/// Home route shown when no story has been selected yet.
#[component]
fn Home() -> Element {
    rsx! {
        div { class: "shell",
            Sidebar { active_id: None::<String> }
            main { class: "content",
                h2 { "Select a component" }
                p { class: "muted", "Browse the title tree on the left and open any story route." }
            }
        }
    }
}

/// Story route that looks up a generated story by id and renders its canvas.
#[component]
fn Component(id: String) -> Element {
    let components = generated::showcase_components();
    let selected = components.into_iter().find(|component| component.id == id.as_str());
    let mut selected_tag = use_context::<Signal<Option<String>>>();
    let active_tag = selected_tag.read().clone();

    rsx! {
        div { class: "shell",
            Sidebar { active_id: Some(id.clone()) }
            main { class: "content",
                if let Some(component) = selected {
                    h2 { "{component.title}" }
                    p { class: "muted", "Route: {COMPONENT_ROUTE_PREFIX}{component.id}" }
                    if component.tags.is_empty() {
                        p { class: "muted", "No tags" }
                    } else {
                        div { class: "tags",
                            for tag in component.tags.iter() {
                                {
                                    let is_active = active_tag.as_deref() == Some(tag.as_str());
                                    let tag_value = tag.clone();
                                    rsx! {
                                        button {
                                            key: "{tag}",
                                            class: if is_active { "tag tag-button active" } else { "tag tag-button" },
                                            onclick: move |_| selected_tag.set(Some(tag_value.clone())),
                                            "{tag}"
                                        }
                                    }
                                }
                            }
                        }
                    }
                    section { class: "canvas", {story_canvas(component)} }
                } else {
                    h2 { "Component not found" }
                    p { class: "muted", "No annotated component matched route id '{id}'." }
                }
            }
        }
    }
}

/// Wraps story rendering in an error boundary so the shell survives story failures.
fn story_canvas(component: generated::ShowcaseComponentDefinition) -> Element {
    rsx! {
        ErrorBoundary {
            handle_error: |errors: ErrorContext| {
                rsx! {
                    div { class: "story-surface story-surface-error",
                        h3 { class: "story-error-title", "Story render failed" }
                        p { class: "muted", "The showcase shell is still running. Fix the story and try again." }
                        pre { class: "story-error-details", "{errors:?}" }
                        button {
                            class: "story-error-retry",
                            onclick: move |_| errors.clear_errors(),
                            "Retry story"
                        }
                    }
                }
            },
            div { class: "story-surface",
                {(component.render)()}
            }
        }
    }
}

/// Fallback route component for unknown paths.
#[component]
fn NotFound(route: Vec<String>) -> Element {
    let attempted = if route.is_empty() {
        "/".to_string()
    } else {
        format!("/{}", route.join("/"))
    };

    rsx! {
        div { class: "shell",
            main { class: "content",
                h2 { "Page not found" }
                p { class: "muted", "Route '{attempted}' does not exist." }
                Link { to: Route::Home {}, class: "back-link", "Back to home" }
            }
        }
    }
}
